{
  "name": "parcelvault-appium-android-tests",
  "version": "1.0.0",
  "description": "Appium E2E Tests for ParcelVault Android Application (Capacitor WebView)",
  "type": "commonjs",
  "scripts": {
    "test": "mocha tests/**/*.test.js --timeout 60000 --reporter spec --exit",
    "test:launch": "mocha tests/01_app_launch.test.js --timeout 60000 --reporter spec --exit",
    "test:auth": "mocha tests/02_auth.test.js --timeout 60000 --reporter spec --exit",
    "test:student": "mocha tests/03_student_flow.test.js --timeout 60000 --reporter spec --exit",
    "test:admin": "mocha tests/04_admin_flow.test.js --timeout 60000 --reporter spec --exit",
    "test:all": "mocha 'tests/**/*.test.js' --timeout 60000 --reporter mocha-junit-reporter --reporter-options mochaFile=./test-results/test-results.xml --exit"
  },
  "dependencies": {
    "@wdio/appium-service": "^9.0.0",
    "appium": "^2.11.0",
    "webdriverio": "^9.0.0"
  },
  "devDependencies": {
    "mocha": "^10.7.3",
    "mocha-junit-reporter": "^2.2.1"
  }
}
