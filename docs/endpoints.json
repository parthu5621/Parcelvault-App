  {
    "path": "/api/auth/login",
    "method": "POST",
    "group": "Authentication",
    "auth": "public",
    "description": "Authenticate an admin or student user and return a JWT token.",
    "request": {
      "headers": {
        "Content-Type": "application/json"
      },
      "body": {
        "email": { "type": "string", "required": true, "description": "User's email address" },
        "password": { "type": "string", "required": true, "description": "User's password" }
      }
    },
    "response": {
      "success": {
        "status": 200,
        "body": {
          "success": true,
          "role": "admin | student",
          "token": "JWT String",
          "user": {
            "id": "UUID String",
            "name": "User's full name",
            "email": "User's email",
            "studentId": "Student-specific ID (only if role is student)",
            "phone": "Student-specific phone number (only if role is student)"
          }
        }
      },
      "errors": [
        {
          "status": 400,
          "body": { "success": false, "error": "Email and password are required" }
        },
        {
          "status": 401,
          "body": { "success": false, "error": "Invalid email or password" }
        }
      ]
    },
    "associated_files": [
      "backend/src/routes/auth.js"
    ],
    "dependencies": [
      "bcryptjs",
      "jsonwebtoken"
    ]
  },
  {
    "path": "/api/auth/register",
    "method": "POST",
    "group": "Authentication",
    "auth": "public",
    "description": "Register a new student or admin account.",
    "request": {
      "headers": {
        "Content-Type": "application/json"
      },
      "body": {
        "name": { "type": "string", "required": true, "description": "Full name" },
        "email": { "type": "string", "required": true, "description": "Email address (must be valid format)" },
        "password": { "type": "string", "required": true, "description": "Password (min 6 chars, containing both letters and numbers)" },
        "role": { "type": "string", "required": false, "default": "student", "description": "Role ('admin' or 'student')" },
        "phone": { "type": "string", "required": "conditional", "description": "Phone number (required for student, min 10 digits)" },
        "studentId": { "type": "string", "required": "conditional", "description": "Unique student identifier (required for student)" }
      }
    },
    "response": {
      "success": {
        "status": 201,
        "body": {
          "success": true,
          "role": "admin | student",
          "token": "JWT String",
          "user": {
            "id": "UUID String",
            "name": "User's name",
            "email": "User's email",
            "studentId": "Student ID (if student)",
            "phone": "Phone number (if student)"
          }
        }
      },
      "errors": [
        {
          "status": 400,
          "body": { "success": false, "error": "Name, email and password are required | Please enter a valid email address | Password must be at least 6 characters | Password must contain both letters and numbers | Phone and student ID are required for student registration | Please enter a valid phone number (min 10 digits)" }
        },
        {
          "status": 409,
          "body": { "success": false, "error": "Email already registered as admin | Email already registered | Student ID already registered" }
        }
      ]
    },
    "associated_files": [
      "backend/src/routes/auth.js"
    ],
    "dependencies": [
      "bcryptjs",
      "jsonwebtoken",
      "crypto"
    ]
  },
